        <ontología-dispositivos:eventDate rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-01-01T00:00:00</ontología-dispositivos:eventDate>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/MAN-001 -->


    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/MAN-001">
