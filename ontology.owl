        <ontología-dispositivos:hasName>Device failure - electrical</ontología-dispositivos:hasName>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/TYPE-001 -->


