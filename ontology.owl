    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/INC-001 -->


    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/INC-001">
