<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#"
     xml:base="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:ontología-dispositivos="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/">
    <owl:Ontology rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/addressesIncident -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/addressesIncident">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Incident"/>
        <rdfs:comment xml:lang="es">Conecta la solución con el problema</rdfs:comment>
        <rdfs:label xml:lang="es">Aborda incidente</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/affectsDevice -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/affectsDevice">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Device"/>
        <rdfs:comment xml:lang="es">Dispositivo afectado</rdfs:comment>
        <rdfs:label xml:lang="es">Afecta al dispositivo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/hasDeviceType -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/hasDeviceType">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Device"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/DeviceType"/>
        <rdfs:comment xml:lang="es">Conecta el dispositivo con su categoría</rdfs:comment>
        <rdfs:label xml:lang="es">Tiene tipo de dispositivo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/hasManufacturer -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/hasManufacturer">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Device"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Manufacturer"/>
        <rdfs:comment xml:lang="es">Relaciona un dispositivo con su fabricante</rdfs:comment>
        <rdfs:label xml:lang="es">Tiene fabricante</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/hasRisk -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/hasRisk">
        <rdfs:comment xml:lang="es">Conecta el incidente con el tipo de riesgo</rdfs:comment>
        <rdfs:label xml:lang="es">Tiene riesgo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/involvedDevice -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/involvedDevice">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Device"/>
        <rdfs:comment xml:lang="es">Indica el dispositivo que causó el accidente</rdfs:comment>
        <rdfs:label xml:lang="es">Dispositivo involucrado</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/isSubclassifiedUnder -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/isSubclassifiedUnder">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/RiskClass"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/RiskClass"/>
        <rdfs:comment xml:lang="es">Propiedad transitiva que indica que una clase se encuentra en un nivel jerárquico inferior</rdfs:comment>
        <rdfs:label xml:lang="es">Subclasificado bajo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/reportingEntity -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/reportingEntity">
        <rdfs:comment>Quien avisa</rdfs:comment>
        <rdfs:label xml:lang="es">Entidad notificadora</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/eventDate -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/eventDate">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="es">Fecha en la que ocurrió el incidente</rdfs:comment>
        <rdfs:label xml:lang="es">Fecha del evento</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/hasName -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/hasName">
        <rdfs:comment xml:lang="es">Nombre de la entidad</rdfs:comment>
        <rdfs:label xml:lang="es">tiene nombre</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/isImplantable -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/isImplantable">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="es">Indica si el dispositivo se implanta en el cuerpo</rdfs:comment>
        <rdfs:label xml:lang="es">Es implantable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ActiveDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ActiveDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/DeviceType"/>
        <rdfs:comment xml:lang="es">Dispositivo sanitario que funciona con corriente eléctrica o con alguna otra fuente de energía que no es la del ser humano</rdfs:comment>
        <rdfs:label xml:lang="es">Dispositivo Activo</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ActiveImplant -->


    <owl:Class rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ActiveImplant">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/DeviceType"/>
        <rdfs:comment xml:lang="es">Dispositivo sanitario que es introducido total o parcialmente al cuerpo humano mediante una intervención quirúrgica o médica</rdfs:comment>
        <rdfs:label xml:lang="es">Implante Activo</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ClassC -->


    <owl:Class rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ClassC">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/RiskClass"/>
        <rdfs:comment xml:lang="es">Alto riesgo individual y/o riesgo moderado para la salud pública</rdfs:comment>
        <rdfs:label xml:lang="es">Clase C</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ClassD -->


    <owl:Class rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ClassD">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/RiskClass"/>
        <rdfs:comment xml:lang="es">Alto riesgo individual y alto riesgo para la salud pública</rdfs:comment>
        <rdfs:label xml:lang="es">Clase D</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ClassI -->


    <owl:Class rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ClassI">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/RiskClass"/>
        <rdfs:comment xml:lang="es">Riesgo bajo</rdfs:comment>
        <rdfs:label xml:lang="es">Clase I</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ClassIII -->


    <owl:Class rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ClassIII">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/RiskClass"/>
        <rdfs:comment xml:lang="es">Riesgo muy alto, generalmente implantes o dispositivos con medicamentos</rdfs:comment>
        <rdfs:label xml:lang="es">Clase III</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ClassIIa -->


    <owl:Class rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ClassIIa">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/RiskClass"/>
        <rdfs:comment xml:lang="es">Riesgo medio</rdfs:comment>
        <rdfs:label xml:lang="es">Clase IIa</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ClassIIb -->


    <owl:Class rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ClassIIb">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/RiskClass"/>
        <rdfs:comment xml:lang="es">Riesgo alto</rdfs:comment>
        <rdfs:label xml:lang="es">Clase IIb</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ContaminationRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ContaminationRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Risk"/>
        <rdfs:comment xml:lang="es">Riesgo mediante el cuál el dispositivo puede introducir agentes externos al paciente o al entorno clínico</rdfs:comment>
        <rdfs:label xml:lang="es">Riesgo de Contaminación</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/CorrectiveAction -->


    <owl:Class rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/CorrectiveAction">
        <rdfs:comment xml:lang="es">Acciones correctivas de seguridad en campo (FSCA) vinculadas a incidentes.</rdfs:comment>
        <rdfs:label xml:lang="es">Acciones correctivas</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/CybersecurityRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/CybersecurityRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Risk"/>
        <rdfs:comment xml:lang="es">Riesgo asociados a vulnerabilidades en dispositivos conectados que pueden comprometer la confidencialidad o disponibilidad de los datos</rdfs:comment>
        <rdfs:label xml:lang="es">Riesgo de Ciberseguridad</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Device -->


    <owl:Class rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Device">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/hasManufacturer"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Manufacturer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Clase que representa un dispositivo médico</rdfs:comment>
        <rdfs:label xml:lang="es">Dispositivo Medico</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://dbpedia.org/resource/Medical_device"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/DeviceType -->


    <owl:Class rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/DeviceType">
        <rdfs:comment xml:lang="es">Todos los tipso de dispositivos que se encuentran listados en los datos</rdfs:comment>
        <rdfs:label xml:lang="es">Tipo de Dispositivo</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/DiagnosticRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/DiagnosticRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Risk"/>
        <rdfs:comment xml:lang="es">Riesgo de que el dispositivo proporcione información incorrecta que lleve a decisiones clínicas erróneas</rdfs:comment>
        <rdfs:label xml:lang="es">Riesgo de Diagnóstico</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ImplantableActiveDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ImplantableActiveDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/DeviceType"/>
        <rdfs:comment xml:lang="es">Dispositivo sanitario que depende de una fuente de energía para funcionar, diseñado para ser introducido total o parcialmente en el cuerpo mediante una intervención quirúrgica o médica y destinado a permanecer allí tras la intervención</rdfs:comment>
        <rdfs:label xml:lang="es">Dispositivo Activo Implantable</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ImplantableDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ImplantableDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/DeviceType"/>
        <rdfs:comment xml:lang="es">Dispositivo sanitario que es implantado totalmente en el cuerpo humano</rdfs:comment>
        <rdfs:label xml:lang="es">Dispositivo Implantable</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/InVitroDiagnosticDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/InVitroDiagnosticDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/DeviceType"/>
        <rdfs:comment xml:lang="es">Dispositivo santiario que se utiliza para diagnosticos, para control, para realizar pruebas, etc.</rdfs:comment>
        <rdfs:label xml:lang="es">Dispositivo de Diagnóstico In Vitro</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Incident -->


    <owl:Class rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Incident">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/involvedDevice"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Device"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Incidentes notificados asociados a dispositivos específicos.</rdfs:comment>
        <rdfs:label xml:lang="es">Incidentes</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://dbpedia.org/resource/Adverse_event"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/InfectionRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/InfectionRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Risk"/>
        <rdfs:comment xml:lang="es">Riesgo de que el dispositivo con programas informáticos incluyan errores de código, fallos de algoritmos o bugs que impidan cumplir su función</rdfs:comment>
        <rdfs:label xml:lang="es">Riesgo de Software</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/InjuryRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/InjuryRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Risk"/>
        <rdfs:comment xml:lang="es">Riesgo de daño físico directo al cuerpo humano resultante del uso de un dispositivo</rdfs:comment>
        <rdfs:label xml:lang="es">Riesgo de Lesión</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/InterferenceRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/InterferenceRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Risk"/>
        <rdfs:comment xml:lang="es">Riesgo de interferencia al dispositivo a causa de campos electromagnéticos o que el propio dispositivo interfiera con otro equipos médicos cercanoses</rdfs:comment>
        <rdfs:label xml:lang="es">Riesgo de Interferencia</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/MalfunctionRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/MalfunctionRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Risk"/>
        <rdfs:comment xml:lang="es">Riesgo de fallo del dispositivo para actuar como espera que funciones el fabricante</rdfs:comment>
        <rdfs:label xml:lang="es">Riesgo de mal funcionamiento</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Manufacturer -->


    <owl:Class rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Manufacturer">
        <rdfs:comment xml:lang="es">Datos de fabricantes europeos (nombre, país, número de autorización).</rdfs:comment>
        <rdfs:label xml:lang="es">Fabricante</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://dbpedia.org/resource/Manufacturer"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/MaterialRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/MaterialRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Risk"/>
        <rdfs:comment xml:lang="es">Peligros derivados de las propiedades físicas, químicas o biológicas de los materiales que componen el dispositivo</rdfs:comment>
        <rdfs:label xml:lang="es">Riesgo de Materiales</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/RadiationRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/RadiationRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Risk"/>
        <rdfs:comment xml:lang="es">Riesgo asociado a la exposición de radiaciones ionizantes o no ionizantes emitidas por el dispositivo</rdfs:comment>
        <rdfs:label xml:lang="es">Riesgo de Radiación</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Risk -->


    <owl:Class rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Risk">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/hasName"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="es">Catálogo de riesgos identificados según la nomenclatura IMDRF.</rdfs:comment>
        <rdfs:label xml:lang="es">Riesgos</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/RiskClass -->


    <owl:Class rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/RiskClass">
        <rdfs:comment xml:lang="es">Todos los riesgos clasificados en clases</rdfs:comment>
        <rdfs:label xml:lang="es">Clases de Riesgos</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/SelfTestDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/SelfTestDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/DeviceType"/>
        <rdfs:comment xml:lang="es">Dispositivo sanitario que puede ser utilizado por una persona que no es del personal médico</rdfs:comment>
        <rdfs:label xml:lang="es">Dispositivo de Autodiagnostico</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/SingleUseDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/SingleUseDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/DeviceType"/>
        <rdfs:comment xml:lang="es">Dispositivo sanitario que se utiliza una sola vez</rdfs:comment>
        <rdfs:label xml:lang="es">Dispositivo de un solo uso</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/SoftwareRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/SoftwareRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Risk"/>
        <rdfs:comment xml:lang="es">Riesgo de transmitir patógenos del dispositivo al paciente</rdfs:comment>
        <rdfs:label xml:lang="es">Riesgo de Infección</rdfs:label>
    </owl:Class>
    


