@prefix : <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#> .

<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#> rdf:type owl:Ontology .

#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/addressesIncident
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/addressesIncident> rdf:type owl:ObjectProperty ;
                                                                                               rdfs:domain <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/CorrectiveAction> ;
                                                                                               rdfs:range <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Incident> ;
                                                                                               rdfs:comment "Conecta la solución con el problema"@es ;
                                                                                               rdfs:label "Aborda incidente"@es .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/affectsDevice
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/affectsDevice> rdf:type owl:ObjectProperty ;
                                                                                           rdfs:domain <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/CorrectiveAction> ;
                                                                                           rdfs:range <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Device> ;
                                                                                           rdfs:comment "Dispositivo afectado"@es ;
                                                                                           rdfs:label "Afecta al dispositivo"@es .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/hasDeviceType
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/hasDeviceType> rdf:type owl:ObjectProperty ;
                                                                                           rdfs:domain <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Device> ;
                                                                                           rdfs:range <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/DeviceType> ;
                                                                                           rdfs:comment "Conecta el dispositivo con su categoría"@es ;
                                                                                           rdfs:label "Tiene tipo de dispositivo"@es .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/hasManufacturer
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/hasManufacturer> rdf:type owl:ObjectProperty ,
                                                                                                      owl:FunctionalProperty ;
                                                                                             rdfs:domain <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Device> ;
                                                                                             rdfs:range <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Manufacturer> ;
                                                                                             rdfs:comment "Relaciona un dispositivo con su fabricante"@es ;
                                                                                             rdfs:label "Tiene fabricante"@es .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/hasRisk
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/hasRisk> rdf:type owl:ObjectProperty ;
                                                                                     rdfs:comment "Conecta el incidente con el tipo de riesgo"@es ;
                                                                                     rdfs:label "Tiene riesgo"@es .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/involvedDevice
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/involvedDevice> rdf:type owl:ObjectProperty ;
                                                                                            rdfs:domain <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Incident> ;
                                                                                            rdfs:range <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Device> ;
                                                                                            rdfs:comment "Indica el dispositivo que causó el accidente"@es ;
                                                                                            rdfs:label "Dispositivo involucrado"@es .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/isSubclassifiedUnder
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/isSubclassifiedUnder> rdf:type owl:ObjectProperty ,
                                                                                                           owl:TransitiveProperty ;
                                                                                                  rdfs:domain <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/RiskClass> ;
                                                                                                  rdfs:range <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/RiskClass> ;
                                                                                                  rdfs:comment "Propiedad transitiva que indica que una clase se encuentra en un nivel jerárquico inferior"@es ;
                                                                                                  rdfs:label "Subclasificado bajo"@es .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/reportingEntity
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/reportingEntity> rdf:type owl:ObjectProperty ;
                                                                                             rdfs:comment "Quien avisa" ;
                                                                                             rdfs:label "Entidad notificadora"@es .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/eventDate
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/eventDate> rdf:type owl:DatatypeProperty ;
                                                                                       rdfs:domain <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Incident> ;
                                                                                       rdfs:range xsd:dateTime ;
                                                                                       rdfs:comment "Fecha en la que ocurrió el incidente"@es ;
                                                                                       rdfs:label "Fecha del evento"@es .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/hasName
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/hasName> rdf:type owl:DatatypeProperty ;
                                                                                     rdfs:comment "Nombre de la entidad"@es ;
                                                                                     rdfs:label "tiene nombre"@es .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/isImplantable
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/isImplantable> rdf:type owl:DatatypeProperty ;
                                                                                           rdfs:domain <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Device> ;
                                                                                           rdfs:range xsd:boolean ;
                                                                                           rdfs:comment "Indica si el dispositivo se implanta en el cuerpo"@es ;
                                                                                           rdfs:label "Es implantable"@es .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ActiveDevice
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ActiveDevice> rdf:type owl:Class ;
                                                                                          rdfs:subClassOf <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/DeviceType> ;
                                                                                          rdfs:comment "Dispositivo sanitario que funciona con corriente eléctrica o con alguna otra fuente de energía que no es la del ser humano"@es ;
                                                                                          rdfs:label "Dispositivo Activo"@es .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ActiveImplant
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ActiveImplant> rdf:type owl:Class ;
                                                                                           rdfs:subClassOf <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/DeviceType> ;
                                                                                           rdfs:comment "Dispositivo sanitario que es introducido total o parcialmente al cuerpo humano mediante una intervención quirúrgica o médica"@es ;
                                                                                           rdfs:label "Implante Activo"@es .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ClassC
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ClassC> rdf:type owl:Class ;
                                                                                    rdfs:subClassOf <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/RiskClass> ;
                                                                                    rdfs:comment "Alto riesgo individual y/o riesgo moderado para la salud pública"@es ;
                                                                                    rdfs:label "Clase C"@es .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ClassD
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ClassD> rdf:type owl:Class ;
                                                                                    rdfs:subClassOf <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/RiskClass> ;
                                                                                    rdfs:comment "Alto riesgo individual y alto riesgo para la salud pública"@es ;
                                                                                    rdfs:label "Clase D"@es .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ClassI
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ClassI> rdf:type owl:Class ;
                                                                                    rdfs:subClassOf <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/RiskClass> ;
                                                                                    rdfs:comment "Riesgo bajo"@es ;
                                                                                    rdfs:label "Clase I"@es .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ClassIII
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ClassIII> rdf:type owl:Class ;
                                                                                      rdfs:subClassOf <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/RiskClass> ;
                                                                                      rdfs:comment "Riesgo muy alto, generalmente implantes o dispositivos con medicamentos"@es ;
                                                                                      rdfs:label "Clase III"@es .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ClassIIa
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ClassIIa> rdf:type owl:Class ;
                                                                                      rdfs:subClassOf <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/RiskClass> ;
                                                                                      rdfs:comment "Riesgo medio"@es ;
                                                                                      rdfs:label "Clase IIa"@es .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ClassIIb
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ClassIIb> rdf:type owl:Class ;
                                                                                      rdfs:subClassOf <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/RiskClass> ;
                                                                                      rdfs:comment "Riesgo alto"@es ;
                                                                                      rdfs:label "Clase IIb"@es .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ContaminationRisk
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ContaminationRisk> rdf:type owl:Class ;
                                                                                               rdfs:subClassOf <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Risk> ;
                                                                                               rdfs:comment "Riesgo mediante el cuál el dispositivo puede introducir agentes externos al paciente o al entorno clínico"@es ;
                                                                                               rdfs:label "Riesgo de Contaminación"@es .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/CorrectiveAction
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/CorrectiveAction> rdf:type owl:Class ;
                                                                                              rdfs:comment "Acciones correctivas de seguridad en campo (FSCA) vinculadas a incidentes."@es ;
                                                                                              rdfs:label "Acciones correctivas"@es .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/CybersecurityRisk
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/CybersecurityRisk> rdf:type owl:Class ;
                                                                                               rdfs:subClassOf <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Risk> ;
                                                                                               rdfs:comment "Riesgo asociados a vulnerabilidades en dispositivos conectados que pueden comprometer la confidencialidad o disponibilidad de los datos"@es ;
                                                                                               rdfs:label "Riesgo de Ciberseguridad"@es .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Device
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Device> rdf:type owl:Class ;
                                                                                    rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                                                      owl:onProperty <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/hasManufacturer> ;
                                                                                                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                                      owl:onClass <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Manufacturer>
                                                                                                    ] ;
                                                                                    rdfs:comment "Clase que representa un dispositivo médico"@es ;
                                                                                    rdfs:label "Dispositivo Medico"@es ;
                                                                                    rdfs:seeAlso <http://dbpedia.org/resource/Medical_device> .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/DeviceType
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/DeviceType> rdf:type owl:Class ;
                                                                                        rdfs:comment "Todos los tipso de dispositivos que se encuentran listados en los datos"@es ;
                                                                                        rdfs:label "Tipo de Dispositivo"@es .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/DiagnosticRisk
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/DiagnosticRisk> rdf:type owl:Class ;
                                                                                            rdfs:subClassOf <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Risk> ;
                                                                                            rdfs:comment "Riesgo de que el dispositivo proporcione información incorrecta que lleve a decisiones clínicas erróneas"@es ;
                                                                                            rdfs:label "Riesgo de Diagnóstico"@es .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ImplantableActiveDevice
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ImplantableActiveDevice> rdf:type owl:Class ;
                                                                                                     rdfs:subClassOf <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/DeviceType> ;
                                                                                                     rdfs:comment "Dispositivo sanitario que depende de una fuente de energía para funcionar, diseñado para ser introducido total o parcialmente en el cuerpo mediante una intervención quirúrgica o médica y destinado a permanecer allí tras la intervención"@es ;
                                                                                                     rdfs:label "Dispositivo Activo Implantable"@es .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ImplantableDevice
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/ImplantableDevice> rdf:type owl:Class ;
                                                                                               rdfs:subClassOf <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/DeviceType> ;
                                                                                               rdfs:comment "Dispositivo sanitario que es implantado totalmente en el cuerpo humano"@es ;
                                                                                               rdfs:label "Dispositivo Implantable"@es .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/InVitroDiagnosticDevice
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/InVitroDiagnosticDevice> rdf:type owl:Class ;
                                                                                                     rdfs:subClassOf <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/DeviceType> ;
                                                                                                     rdfs:comment "Dispositivo santiario que se utiliza para diagnosticos, para control, para realizar pruebas, etc."@es ;
                                                                                                     rdfs:label "Dispositivo de Diagnóstico In Vitro"@es .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Incident
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Incident> rdf:type owl:Class ;
                                                                                      rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                                                        owl:onProperty <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/involvedDevice> ;
                                                                                                        owl:someValuesFrom <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Device>
                                                                                                      ] ;
                                                                                      rdfs:comment "Incidentes notificados asociados a dispositivos específicos."@es ;
                                                                                      rdfs:label "Incidentes"@es ;
                                                                                      rdfs:seeAlso <http://dbpedia.org/resource/Adverse_event> .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/InfectionRisk
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/InfectionRisk> rdf:type owl:Class ;
                                                                                           rdfs:subClassOf <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Risk> ;
                                                                                           rdfs:comment "Riesgo de que el dispositivo con programas informáticos incluyan errores de código, fallos de algoritmos o bugs que impidan cumplir su función"@es ;
                                                                                           rdfs:label "Riesgo de Software"@es .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/InjuryRisk
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/InjuryRisk> rdf:type owl:Class ;
                                                                                        rdfs:subClassOf <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Risk> ;
                                                                                        rdfs:comment "Riesgo de daño físico directo al cuerpo humano resultante del uso de un dispositivo"@es ;
                                                                                        rdfs:label "Riesgo de Lesión"@es .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/InterferenceRisk
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/InterferenceRisk> rdf:type owl:Class ;
                                                                                              rdfs:subClassOf <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Risk> ;
                                                                                              rdfs:comment "Riesgo de interferencia al dispositivo a causa de campos electromagnéticos o que el propio dispositivo interfiera con otro equipos médicos cercanoses"@es ;
                                                                                              rdfs:label "Riesgo de Interferencia"@es .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/MalfunctionRisk
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/MalfunctionRisk> rdf:type owl:Class ;
                                                                                             rdfs:subClassOf <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Risk> ;
                                                                                             rdfs:comment "Riesgo de fallo del dispositivo para actuar como espera que funciones el fabricante"@es ;
                                                                                             rdfs:label "Riesgo de mal funcionamiento"@es .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Manufacturer
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Manufacturer> rdf:type owl:Class ;
                                                                                          rdfs:comment "Datos de fabricantes europeos (nombre, país, número de autorización)."@es ;
                                                                                          rdfs:label "Fabricante"@es ;
                                                                                          rdfs:seeAlso <http://dbpedia.org/resource/Manufacturer> .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/MaterialRisk
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/MaterialRisk> rdf:type owl:Class ;
                                                                                          rdfs:subClassOf <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Risk> ;
                                                                                          rdfs:comment "Peligros derivados de las propiedades físicas, químicas o biológicas de los materiales que componen el dispositivo"@es ;
                                                                                          rdfs:label "Riesgo de Materiales"@es .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/RadiationRisk
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/RadiationRisk> rdf:type owl:Class ;
                                                                                           rdfs:subClassOf <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Risk> ;
                                                                                           rdfs:comment "Riesgo asociado a la exposición de radiaciones ionizantes o no ionizantes emitidas por el dispositivo"@es ;
                                                                                           rdfs:label "Riesgo de Radiación"@es .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Risk
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/Risk> rdf:type owl:Class ;
                                                                                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                                                    owl:onProperty <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/hasName> ;
                                                                                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                                    owl:onDataRange xsd:string
                                                                                                  ] ;
                                                                                  rdfs:comment "Catálogo de riesgos identificados según la nomenclatura IMDRF."@es ;
                                                                                  rdfs:label "Riesgos"@es .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/RiskClass
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/RiskClass> rdf:type owl:Class ;
                                                                                       rdfs:comment "Todos los riesgos clasificados en clases"@es ;
                                                                                       rdfs:label "Clases de Riesgos"@es .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/SelfTestDevice
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/SelfTestDevice> rdf:type owl:Class ;
                                                                                            rdfs:subClassOf <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/DeviceType> ;
                                                                                            rdfs:comment "Dispositivo sanitario que puede ser utilizado por una persona que no es del personal médico"@es ;
                                                                                            rdfs:label "Dispositivo de Autodiagnostico"@es .


###  http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/SingleUseDevice
<http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/SingleUseDevice> rdf:type owl:Class ;
                                                                                             rdfs:subClassOf <http://www.semanticweb.org/valrg/ontologies/2026/5/ontología-dispositivos#/DeviceType> ;
                                                                                             rdfs:comment "Dispositivo sanitario que se utiliza una sola vez"@es ;
